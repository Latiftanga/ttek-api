# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=sis_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=sis_db
DATABASE_URL=postgresql+asyncpg://sis_user:your_postgres_password@postgres:5432/sis_db

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@redis:6379/0

# ── CouchDB ──────────────────────────────────────────────────
COUCHDB_USER=admin
COUCHDB_PASSWORD=your_couchdb_password
COUCHDB_URL=http://admin:your_couchdb_password@couchdb:5984

# ── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_URL=http://minio:9000

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_APP_NAME=Ghana SIS
NEXT_PUBLIC_COUCHDB_URL=http://localhost:5984
